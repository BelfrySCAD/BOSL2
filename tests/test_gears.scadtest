test_spur_gear();
'''

[[test]]
name = "test_rack2d"
script = '''
include <../std.scad>
include <../gears.scad>

module test_rack2d() {
    // rack2d uses 'backing' for underside height, not 'height'
    v = rack2d(mod=2, teeth=5, backing=5);
    assert(is_path(v, 2) || is_region(v));
}
test_rack2d();
'''

[[test]]
name = "test_rack"
assert_no_echoes = false
script = '''
include <../std.scad>
include <../gears.scad>

module test_rack() {
    // rack uses 'backing' for underside height
    // herringbone=true uses sweep() instead of linear_sweep(), avoiding anchor bug
    v = rack(mod=2, teeth=10, thickness=5, backing=5, helical=20, herringbone=true);
    assert(is_vnf(v));
    assert(len(v[0]) > 0);
}
test_rack();
'''

[[test]]
name = "test_planetary_gears"
script = '''
include <../std.scad>
include <../gears.scad>

module test_planetary_gears() {
    // Returns [["sun", z, ps, spin], ["ring", ...], ["planets", ...], ["ratio", ...]]
    result = planetary_gears(n=3, max_teeth=50, mod=2, ring_carrier=1.5);
    assert(is_list(result));
    assert(len(result) == 4);
    // First entry is sun gear info, second is ring, third is planets, fourth is ratio
    assert(result[0][0] == "sun");
    assert(result[1][0] == "ring");
    assert(result[3][0] == "ratio");
    // Tooth counts are positive integers
    assert(is_int(result[0][1]) && result[0][1] > 0);
    assert(is_int(result[1][1]) && result[1][1] > 0);
}
test_planetary_gears();
'''


[[test]]
name = "test_spur_gear2d"
script = '''
include <../std.scad>
include <../gears.scad>

module test_spur_gear2d() {
    $fn = 4;
    v = spur_gear2d(mod=2, teeth=12);
    assert(is_region(v) || is_path(v, 2));
    assert(len(v) > 0);
}
test_spur_gear2d();
'''

[[test]]
name = "test_spur_gear"
assert_no_echoes = false
script = '''
include <../std.scad>
include <../gears.scad>

module test_spur_gear() {
    $fn = 4;
    v = spur_gear(mod=2, teeth=12, thickness=5);
    assert(is_vnf(v));
    assert(len(v[0]) > 0);

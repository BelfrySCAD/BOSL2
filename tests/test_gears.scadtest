[[test]]
name = "test_circular_pitch"
script = '''
include <../std.scad>
include <../gears.scad>

module test_circular_pitch() {
    // circular_pitch from mod: mod * PI
    assert_approx(circular_pitch(mod=2), 2*PI);
    // circular_pitch from circ_pitch: identity
    assert_approx(circular_pitch(circ_pitch=5), 5);
}
test_circular_pitch();
'''

[[test]]
name = "test_diametral_pitch"
script = '''
include <../std.scad>
include <../gears.scad>

module test_diametral_pitch() {
    // diametral pitch from circ_pitch: PI/circ_pitch * INCH
    cp = 5;
    dp = diametral_pitch(circ_pitch=cp);
    assert(dp > 0);
    // from mod: PI/(mod*PI)*INCH = INCH/mod
    dp2 = diametral_pitch(mod=2);
    assert(dp2 > 0);
}
test_diametral_pitch();
'''

[[test]]
name = "test_module_value"
script = '''
include <../std.scad>
include <../gears.scad>

module test_module_value() {
    // module from circ_pitch: circ_pitch / PI
    assert_approx(module_value(circ_pitch=PI), 1);
    assert_approx(module_value(mod=3), 3);
}
test_module_value();
'''

[[test]]
name = "test_pitch_radius"
script = '''
include <../std.scad>
include <../gears.scad>

module test_pitch_radius() {
    // pitch_radius = circ_pitch * teeth / (2*PI)
    pr = pitch_radius(mod=2, teeth=20);
    assert_approx(pr, 20);  // mod*teeth/2 = 2*20/2 = 20
}
test_pitch_radius();
'''

[[test]]
name = "test_outer_radius"
script = '''
include <../std.scad>
include <../gears.scad>

module test_outer_radius() {
    // outer_radius > pitch_radius for external gears
    pr = pitch_radius(mod=2, teeth=20);
    or = outer_radius(mod=2, teeth=20);
    assert(or > pr);
}
test_outer_radius();
'''

[[test]]
name = "test_root_radius"
script = '''
include <../std.scad>
include <../gears.scad>

module test_root_radius() {
    // root_radius < pitch_radius for external gears
    pr = pitch_radius(mod=2, teeth=20);
    rr = root_radius(mod=2, teeth=20);
    assert(rr < pr);
}
test_root_radius();
'''

[[test]]
name = "test_bevel_pitch_angle"
script = '''
include <../std.scad>
include <../gears.scad>

module test_bevel_pitch_angle() {
    // Equal teeth → 45° pitch angle at 90° drive angle
    angle = bevel_pitch_angle(teeth=20, mate_teeth=20);
    assert_approx(angle, 45);
    // More mate teeth → smaller pitch angle
    angle2 = bevel_pitch_angle(teeth=10, mate_teeth=20);
    assert(angle2 < 45);
}
test_bevel_pitch_angle();
'''

[[test]]
name = "test_gear_dist"
script = '''
include <../std.scad>
include <../gears.scad>

module test_gear_dist() {
    // Standard center distance = sum of pitch radii
    d = gear_dist(mod=2, teeth1=20, teeth2=20);
    pr = pitch_radius(mod=2, teeth=20);
    assert_approx(d, 2*pr);
}
test_gear_dist();
'''

[[test]]
name = "test_auto_profile_shift"
script = '''
include <../std.scad>
include <../gears.scad>

module test_auto_profile_shift() {
    // Large tooth count → zero shift
    ps = auto_profile_shift(teeth=30);
    assert(is_num(ps));
    assert(ps <= 1);
}
test_auto_profile_shift();
'''

[[test]]
name = "test_get_profile_shift"
script = '''
include <../std.scad>
include <../gears.scad>

module test_get_profile_shift() {
    // Use ring+spur example from docs: ring=57 teeth, spur=25 teeth, mod=2, desired=34
    // internal1=true means ring gear; returns ~1.2
    ps = get_profile_shift(desired=34, teeth1=57, teeth2=25, mod=2, internal1=true);
    assert(is_num(ps));
    assert(ps > 0);
}
test_get_profile_shift();
'''

[[test]]
name = "test_gear_shorten"
script = '''
include <../std.scad>
include <../gears.scad>

module test_gear_shorten() {
    // gear_shorten doesn't take a pitch parameter — uses teeth only
    gs = gear_shorten(teeth1=20, teeth2=20);
    assert(is_num(gs));
}
test_gear_shorten();
'''


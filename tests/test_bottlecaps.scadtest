[[test]]
name = "test_sp_diameter"
script = '''
include <../std.scad>
include <../bottlecaps.scad>

module test_sp_diameter() {
    d = sp_diameter(48, 400);
    assert(is_num(d));
    assert(d > 0);
}
test_sp_diameter();
'''

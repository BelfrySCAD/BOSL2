[[test]]
name = "test_sp_neck"
script = '''
include <../std.scad>
include <../bottlecaps.scad>

module test_sp_neck() {
    $fn = 8;
    sp_neck(48, 400, 2);
}
test_sp_neck();
'''

[[test]]
name = "test_sp_cap"
script = '''
include <../std.scad>
include <../bottlecaps.scad>


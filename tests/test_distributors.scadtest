[[test]]
name = "test_arc_copies"
script = '''
include <../std.scad>

module test_arc_copies() {
    mats = arc_copies(n=6, r=10);
    assert(len(mats) == 6);
    // with p=: 6 copies around a circle of radius 10
    pts = arc_copies(n=4, r=5, p=[[0,0,0]]);
    assert(len(pts) == 4);
}
test_arc_copies();
'''

[[test]]
name = "test_grid_copies"
script = '''
include <../std.scad>

module test_grid_copies() {
    mats = grid_copies(spacing=10, n=[3,2]);
    assert(len(mats) == 6);
    pts = grid_copies(spacing=10, n=[2,2], p=[0,0,0]);
    assert(len(pts) == 4);
    assert_equal(pts, [[-5,-5,0],[5,-5,0],[-5,5,0],[5,5,0]]);
}
test_grid_copies();
'''

[[test]]
name = "test_path_copies"
script = '''
include <../std.scad>

module test_path_copies() {
    path = [[0,0,0],[10,0,0],[20,0,0]];
    mats = path_copies(path, n=3);
    assert(len(mats) == 3);
}
test_path_copies();
'''


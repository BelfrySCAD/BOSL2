[[test]]
name = "test_line_copies"
script = '''
include <../std.scad>

module test_line_copies() {
    assert_equal(line_copies(l=100,n=5,p=[0,0,0]), [[-50,0,0],[-25,0,0],[0,0,0],[25,0,0],[50,0,0]]);
    assert_equal(line_copies(20,n=5,p=[0,0,0]), [[-40,0,0],[-20,0,0],[0,0,0],[20,0,0],[40,0,0]]);
    assert_equal(line_copies(spacing=20,n=5,p=[0,0,0]), [[-40,0,0],[-20,0,0],[0,0,0],[20,0,0],[40,0,0]]);
    assert_equal(line_copies(spacing=[0,20],n=5,p=[0,0,0]), [[0,-40,0],[0,-20,0],[0,0,0],[0,20,0],[0,40,0]]);

    assert_equal(line_copies(p1=[0,0],l=100,n=5,p=[0,0,0]), [[0,0,0],[25,0,0],[50,0,0],[75,0,0],[100,0,0]]);
    assert_equal(line_copies(p1=[0,0],20,n=5,p=[0,0,0]), [[0,0,0],[20,0,0],[40,0,0],[60,0,0],[80,0,0]]);
    assert_equal(line_copies(p1=[0,0],spacing=20,n=5,p=[0,0,0]), [[0,0,0],[20,0,0],[40,0,0],[60,0,0],[80,0,0]]);
    assert_equal(line_copies(p1=[0,0],spacing=[0,20],n=5,p=[0,0,0]), [[0,0,0],[0,20,0],[0,40,0],[0,60,0],[0,80,0]]);
}
test_line_copies();
'''

[[test]]
name = "test_move_copies"
script = '''
include <../std.scad>

module test_move_copies() {
    // function form: returns list of translation matrices
    mats = move_copies([[0,0,0],[10,0,0],[20,0,0]]);
    assert(len(mats) == 3);
    // with p=: applies matrices to point
    pts = move_copies([[0,0,0],[10,0,0],[20,0,0]], p=[0,0,0]);
    assert_equal(pts, [[0,0,0],[10,0,0],[20,0,0]]);
}
test_move_copies();
'''

[[test]]
name = "test_xcopies"
script = '''
include <../std.scad>

module test_xcopies() {
    // function form: returns translation matrices
    mats = xcopies(10, n=3);
    assert(len(mats) == 3);
    // with p=: transforms a point
    pts = xcopies(10, n=3, p=[0,0,0]);
    assert_equal(pts, [[-10,0,0],[0,0,0],[10,0,0]]);
}
test_xcopies();
'''

[[test]]
name = "test_ycopies"
script = '''
include <../std.scad>

module test_ycopies() {
    mats = ycopies(10, n=3);
    assert(len(mats) == 3);
    pts = ycopies(10, n=3, p=[0,0,0]);
    assert_equal(pts, [[0,-10,0],[0,0,0],[0,10,0]]);
}
test_ycopies();
'''

[[test]]
name = "test_zcopies"
script = '''
include <../std.scad>

module test_zcopies() {
    mats = zcopies(10, n=3);
    assert(len(mats) == 3);
    pts = zcopies(10, n=3, p=[0,0,0]);
    assert_equal(pts, [[0,0,-10],[0,0,0],[0,0,10]]);
}
test_zcopies();
'''

[[test]]
name = "test_xflip_copy"
script = '''
include <../std.scad>

module test_xflip_copy() {
    mats = xflip_copy();
    assert(len(mats) == 2);
    pts = xflip_copy(p=[[5,3,0]]);
    assert(len(pts) == 2);
    // original and mirrored
    assert_approx(pts[0][0], [5,3,0]);
    assert_approx(pts[1][0], [-5,3,0]);
}
test_xflip_copy();
'''

[[test]]
name = "test_yflip_copy"
script = '''
include <../std.scad>

module test_yflip_copy() {
    mats = yflip_copy();
    assert(len(mats) == 2);
    pts = yflip_copy(p=[[3,5,0]]);
    assert(len(pts) == 2);
    assert_approx(pts[0][0], [3,5,0]);
    assert_approx(pts[1][0], [3,-5,0]);
}
test_yflip_copy();
'''

[[test]]
name = "test_zflip_copy"
script = '''
include <../std.scad>

module test_zflip_copy() {
    mats = zflip_copy();
    assert(len(mats) == 2);
    pts = zflip_copy(p=[[3,0,7]]);
    assert(len(pts) == 2);
    assert_approx(pts[0][0], [3,0,7]);
    assert_approx(pts[1][0], [3,0,-7]);
}
test_zflip_copy();
'''

[[test]]
name = "test_mirror_copy"
script = '''
include <../std.scad>

module test_mirror_copy() {
    mats = mirror_copy(v=[1,0,0]);
    assert(len(mats) == 2);
    pts = mirror_copy(v=[1,0,0], p=[[5,0,0]]);
    assert(len(pts) == 2);
    assert_approx(pts[0][0], [5,0,0]);
    assert_approx(pts[1][0], [-5,0,0]);
}
test_mirror_copy();
'''

[[test]]
name = "test_rot_copies"
script = '''
include <../std.scad>

module test_rot_copies() {
    // n rotations of 360/n each around Z
    mats = rot_copies(n=4);
    assert(len(mats) == 4);
    // with p=: transforms a point
    pts = rot_copies(n=4, p=[[10,0,0]]);
    assert(len(pts) == 4);
    // first copy at 0°, second at 90°, etc.
    assert_approx(pts[0][0], [10,0,0]);
    assert_approx(pts[1][0], [0,10,0]);
}
test_rot_copies();
'''

[[test]]
name = "test_xrot_copies"
script = '''

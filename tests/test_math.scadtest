[[test]]
name = "test_count"
script = '''
include <../std.scad>

module test_count() {
    assert_equal(count(5), [0,1,2,3,4]);
    assert_equal(count(5,3), [3,4,5,6,7]);
    assert_equal(count(4,3,2), [3,5,7,9]);
    assert_equal(count(5,0,0.25), [0, 0.25, 0.5, 0.75, 1.0]);
}
test_count();
'''


[[test]]
name = "test_lerpn"
script = '''
include <../std.scad>

module test_lerpn() {
    assert_approx(lerpn(0, 4, 5), [0,1,2,3,4]);
    assert_approx(lerpn(0, 1, 3), [0, 0.5, 1]);
    // endpoint=false excludes endpoint
    v = lerpn(0, 1, 4, endpoint=false);
    assert(len(v) == 4);
    assert_approx(v[0], 0);
    assert_approx(v[3], 0.75);
}
test_lerpn();
'''

[[test]]
name = "test_bilerp"
script = '''
include <../std.scad>

module test_bilerp() {
    // corners: [f(0,0), f(1,0), f(0,1), f(1,1)]
    pts = [0, 1, 0, 1];  // linear in x, independent of y
    assert_approx(bilerp(pts, 0, 0), 0);
    assert_approx(bilerp(pts, 1, 0), 1);
    assert_approx(bilerp(pts, 0.5, 0.5), 0.5);
    // uniform corners → constant
    assert_approx(bilerp([3,3,3,3], 0.3, 0.7), 3);
}
test_bilerp();
'''

[[test]]
name = "test_fit_to_range"
script = '''
include <../std.scad>

module test_fit_to_range() {
    v = fit_to_range([1,2,3,4,5], 0, 1);
    assert_approx(v[0], 0);
    assert_approx(v[4], 1);
    assert_approx(v[2], 0.5);
    // constant input → returned unchanged (no range to normalize)
    v2 = fit_to_range([3,3,3], 0, 10);
    assert_approx(v2[0], 3);
}
test_fit_to_range();
'''

[[test]]
name = "test_slerp"
script = '''
include <../std.scad>

module test_slerp() {
    v1 = [1,0,0];
    v2 = [0,1,0];
    // endpoints
    assert_approx(slerp(v1, v2, 0), [1,0,0]);
    assert_approx(slerp(v1, v2, 1), [0,1,0]);
    // midpoint should be unit vector at 45°
    mid = slerp(v1, v2, 0.5);
    assert_approx(norm(mid), 1);
    assert_approx(mid, unit([1,1,0]));
}
test_slerp();
'''

[[test]]
name = "test_slerpn"
script = '''
include <../std.scad>

module test_slerpn() {
    pts = slerpn([1,0,0], [0,1,0], 3);
    assert(len(pts) == 3);
    assert_approx(pts[0], [1,0,0]);
    assert_approx(pts[2], [0,1,0]);
    for (p = pts) assert_approx(norm(p), 1);
    // endpoint=false
    pts2 = slerpn([1,0,0], [0,1,0], 4, endpoint=false);
    assert(len(pts2) == 4);
    assert_approx(pts2[0], [1,0,0]);
}
test_slerpn();
'''

[[test]]
name = "test_random_points"
script = '''
include <../std.scad>

module test_random_points() {
    pts = random_points(n=10, dim=3, scale=1, seed=42);
    assert(len(pts) == 10);
    assert(len(pts[0]) == 3);
    pts2 = random_points(n=20, dim=2, scale=2, seed=7);
    assert(len(pts2) == 20);
    assert(len(pts2[0]) == 2);
}
test_random_points();
'''

[[test]]
name = "test_exponential_rands"
script = '''
include <../std.scad>

module test_exponential_rands() {
    v = exponential_rands(n=50, lambda=1, seed=99);
    assert(len(v) == 50);
    assert(all_positive(v));  // exponential distribution is always positive
}
test_exponential_rands();
'''

[[test]]
name = "test_spherical_random_points"
script = '''
include <../std.scad>

module test_spherical_random_points() {
    pts = spherical_random_points(n=10, radius=5, seed=123);
    assert(len(pts) == 10);
    for (p = pts) assert_approx(norm(p), 5);
}
test_spherical_random_points();
'''

[[test]]
name = "test_random_polygon"
script = '''

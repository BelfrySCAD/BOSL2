[[test]]
name = "test_threaded_rod"
script = '''
include <../std.scad>
include <../threading.scad>

module test_threaded_rod() {
    $fn = 8;
    threaded_rod(d=8, l=5, pitch=2, blunt_start=false);
}
test_threaded_rod();
'''

[[test]]
name = "test_threaded_nut"
script = '''
include <../std.scad>
include <../threading.scad>

module test_threaded_nut() {
    $fn = 8;
    threaded_nut(nutwidth=14, id=8, h=5, pitch=2);
}
test_threaded_nut();
'''


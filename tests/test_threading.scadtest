[[test]]
name = "test_generic_threaded_rod"
script = '''
include <../std.scad>
include <../threading.scad>

module test_generic_threaded_rod() {
    $fn = 8;
    // Triangular profile: X in [-0.5, 0.5], Y=0 at peak, -0.5 at valley
    profile = [[-0.5, -0.5], [0, 0], [0.5, -0.5]];
    generic_threaded_rod(d=8, l=5, pitch=2, profile=profile, blunt_start=false);
}
test_generic_threaded_rod();
'''

[[test]]
name = "test_generic_threaded_nut"
script = '''
include <../std.scad>
include <../threading.scad>

module test_generic_threaded_nut() {
    $fn = 8;
    profile = [[-0.5, -0.5], [0, 0], [0.5, -0.5]];
    generic_threaded_nut(nutwidth=14, id=8, h=5, pitch=2, profile=profile);
}
test_generic_threaded_nut();
'''


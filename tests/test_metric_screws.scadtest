[[test]]
name = "test_get_metric_bolt_head_size"
assert_no_echoes = false
script = '''
include <../std.scad>
include <../metric_screws.scad>

module test_get_metric_bolt_head_size() {
    assert_approx(get_metric_bolt_head_size(4),  7.0);
    assert_approx(get_metric_bolt_head_size(6), 10.0);
    assert_approx(get_metric_bolt_head_size(10), 17.0);
}
test_get_metric_bolt_head_size();
'''

[[test]]
name = "test_get_metric_bolt_head_height"
assert_no_echoes = false
script = '''
include <../std.scad>
include <../metric_screws.scad>


    assert_approx(get_metric_bolt_head_height(4),  2.93);
    assert_approx(get_metric_bolt_head_height(8),  5.45);
    assert_approx(get_metric_bolt_head_height(16), 10.18);
}
test_get_metric_bolt_head_height();
'''


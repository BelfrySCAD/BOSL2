[[test]]
name = "test_half_joiner_clear"
script = '''
include <../std.scad>
include <../joiners.scad>

module test_half_joiner_clear() {
    $fn = 8;
    v = half_joiner_clear(l=10, w=8);
    assert(is_vnf(v));
    assert(len(v[0]) > 0);
}
test_half_joiner_clear();
'''

[[test]]
name = "test_half_joiner"
script = '''
include <../std.scad>
include <../joiners.scad>

module test_half_joiner() {
    $fn = 8;
    v = half_joiner(l=10, w=8, base=5);
    assert(is_vnf(v));
    assert(len(v[0]) > 0);
}
test_half_joiner();
'''


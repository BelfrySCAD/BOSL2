[[test]]
name = "test_metaballs"
script = '''
include <../std.scad>
include <../isosurface.scad>

module test_metaballs() {
    // Two spheres with large voxels for fast computation
    spec = [IDENT, mb_sphere(r=5)];
    v = metaballs(spec, bounding_box=[[-10,-10,-10],[10,10,10]], voxel_size=4);
    assert(is_vnf(v));
    assert(len(v[0]) > 0);
    assert(len(v[1]) > 0);
}
test_metaballs();
'''

[[test]]
name = "test_metaballs2d"
script = '''
include <../std.scad>
include <../isosurface.scad>

module test_metaballs2d() {
    spec = [IDENT, mb_circle(r=5)];
    result = metaballs2d(spec, bounding_box=[[-10,-10],[10,10]], pixel_size=3);
    assert(is_region(result) || is_path(result, 2));
    assert(len(result) > 0);
}
test_metaballs2d();
'''

[[test]]
name = "test_isosurface"
script = '''
include <../std.scad>
include <../isosurface.scad>

module test_isosurface() {
    // Sphere: f(x,y,z) = x^2+y^2+z^2; isovalue=[0,25] gives solid sphere of radius 5
    v = isosurface(
        function(x,y,z) x*x + y*y + z*z,
        isovalue = [0, 25],
        bounding_box = [[-8,-8,-8],[8,8,8]],
        voxel_size = 4
    );
    assert(is_vnf(v));
    assert(len(v[0]) > 0);
    assert(len(v[1]) > 0);
}
test_isosurface();
'''

[[test]]
name = "test_contour"
script = '''
include <../std.scad>
include <../isosurface.scad>

module test_contour() {
    // Circle: f(x,y) = x^2+y^2; isovalue=[0,25] gives filled circle of radius 5
    result = contour(
        function(x,y) x*x + y*y,
        isovalue = [0, 25],
        bounding_box = [[-8,-8],[8,8]],
        pixel_size = 3
    );
    assert(is_region(result) || is_path(result, 2));
    assert(len(result) > 0);
}
test_contour();
'''

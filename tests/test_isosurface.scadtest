[[test]]
name = "test_mb_cutoff"
script = '''
include <../std.scad>
include <../isosurface.scad>

module test_mb_cutoff() {
    // At dist=0: full strength = 1
    assert_approx(mb_cutoff(0, 10), 1);
    // At dist >= cutoff: zero
    assert_approx(mb_cutoff(10, 10), 0);
    assert_approx(mb_cutoff(15, 10), 0);
    // Mid-range: between 0 and 1
    v = mb_cutoff(5, 10);
    assert(v > 0 && v < 1);
}
test_mb_cutoff();
'''

[[test]]
name = "test_debug_tetra"
script = '''
include <../std.scad>
include <../isosurface.scad>

module test_debug_tetra() {
    // Returns a VNF (tetrahedron) for debugging display
    v = debug_tetra(1);
    assert(is_vnf(v));
    assert(len(v[0]) == 4);   // 4 vertices
    assert(len(v[1]) == 4);   // 4 triangular faces
}
test_debug_tetra();
'''

[[test]]
name = "test_mb_sphere"
script = '''
include <../std.scad>
include <../isosurface.scad>

module test_mb_sphere() {
    spec = mb_sphere(r=5);
    // Returns [function_literal, [sign, debug_vnf]]
    assert(is_list(spec));
    assert(len(spec) == 2);
    assert(is_function(spec[0]));
    // The function returns a field value at a point
    val = spec[0]([0,0,0]);
    assert(is_num(val));
    assert(val > 0);  // positive metaball at origin
}
test_mb_sphere();
'''

